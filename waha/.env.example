# =============================================
# WAHA — WhatsApp Service for BlueMQ
# =============================================

# ─── WAHA Security ───────────────────────────────────────────
# Strong secret key — used to authenticate API calls to WAHA
# Same value must be set as WAHA_API_KEY in BlueMQ's .env
# Generate with: openssl rand -hex 32
WHATSAPP_API_KEY=your_waha_api_key_here

# ─── Webhook ─────────────────────────────────────────────────
# URL where WAHA sends session status updates
# Must be your BlueMQ PUBLIC URL (not internal Docker network)
# WAHA calls this from inside Docker, so use host.docker.internal on local
# or your public domain in production
WHATSAPP_HOOK_URL=http://host.docker.internal:3001/whatsapp/sessions/webhook?secret=477132cf8732dfd6b9ae2d443ad22bb2dd69201956192cadb6eb431e6b88624b

# Which events WAHA sends to webhook
# session.status covers: WORKING, FAILED, STOPPED
WHATSAPP_HOOK_EVENTS=session.status

# ─── Engine ──────────────────────────────────────────────────
# WEBJS = WhatsApp Web JS (stable, recommended)
# NOWEB = lighter, no browser (WAHA Plus only)
WHATSAPP_DEFAULT_ENGINE=WEBJS

# ─── Logging ─────────────────────────────────────────────────
WAHA_LOG_LEVEL=info

# ─── Local dev only ──────────────────────────────────────────
PORT=3000
