# =============================================
# WAHA — WhatsApp Service for BlueMQ
# =============================================

# ─── WAHA Security ───────────────────────────────────────────
# Strong secret key — used to authenticate API calls to WAHA
# Same value goes into notification-service as WAHA_API_KEY
WHATSAPP_API_KEY=04e8bbbac2dcd938c00bb15326c4d605954a34f592c95d0089d675e3773e6450

# ─── Webhook ─────────────────────────────────────────────────
# URL where WAHA sends session status updates
# Must be your notification-service PUBLIC URL
# WAHA calls this from outside Railway so must be public
WHATSAPP_HOOK_URL=https://YOUR-NOTIFICATION-SERVICE.railway.app/whatsapp/sessions/webhook?secret=477132cf8732dfd6b9ae2d443ad22bb2dd69201956192cadb6eb431e6b88624b

# Which events WAHA sends to webhook
# session.status covers: WORKING, FAILED, STOPPED
WHATSAPP_HOOK_EVENTS=session.status

# ─── Engine ──────────────────────────────────────────────────
# WEBJS = WhatsApp Web JS (stable, recommended)
# NOWEB = lighter, no browser (WAHA Plus only)
WHATSAPP_DEFAULT_ENGINE=WEBJS

# ─── Logging ─────────────────────────────────────────────────
WAHA_LOG_LEVEL=info

# ─── Local dev only ──────────────────────────────────────────
PORT=3000
