{
  "name": "bluemq",
  "version": "1.0.0",
  "description": "Production-grade notification service with BullMQ, provider abstraction, and multi-channel delivery",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:api": "node src/index.js --mode=api",
    "start:worker": "node src/index.js --mode=worker",
    "dev": "nodemon src/index.js",
    "dev:api": "nodemon src/index.js --mode=api",
    "dev:worker": "nodemon src/index.js --mode=worker",
    "migrate": "node src/db/migrate.js",
    "test:db": "node scripts/test-db-connection.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "notifications",
    "bullmq",
    "onesignal",
    "push",
    "email",
    "sms"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "axios": "^1.13.5",
    "bullmq": "^5.70.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "resend": "^6.9.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
