# =============================================
# BlueMQ — Notification Service
# =============================================

# ─── Database (Neon) ───
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# ─── Redis (BullMQ) ───
# Modes: single | sentinel | cluster
REDIS_MODE=single

# Single / managed endpoint (DigitalOcean Managed Redis, Upstash, Railway, etc.)
REDIS_URL=redis://default:password@host:port
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_LAZY_CONNECT=false
REDIS_TLS_ENABLED=false
REDIS_TLS_REJECT_UNAUTHORIZED=true

# Sentinel mode
# REDIS_SENTINELS=10.0.0.11:26379,10.0.0.12:26379,10.0.0.13:26379
# REDIS_SENTINEL_NAME=mymaster
# REDIS_SENTINEL_USERNAME=
# REDIS_SENTINEL_PASSWORD=

# Cluster mode
# REDIS_CLUSTER_NODES=10.0.0.21:6379,10.0.0.22:6379,10.0.0.23:6379
# REDIS_CLUSTER_SCALE_READS=master
# REDIS_CLUSTER_MAX_REDIRECTIONS=16

# ─── OneSignal ───
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key

# ─── Firebase Cloud Messaging (Push) ───
# Option A: full JSON in one variable
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# Option B: split fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Provider Routing (exactly one true per channel) ───
PROVIDER_PUSH_ONESIGNAL=true
PROVIDER_PUSH_FIREBASE=false

PROVIDER_EMAIL_ONESIGNAL=false
PROVIDER_EMAIL_RESEND=true

PROVIDER_SMS_ONESIGNAL=true

# ─── Resend (Email) ───
RESEND_API_KEY=
RESEND_FROM_EMAIL=BlueMQ <noreply@example.com>

# ─── WAHA (WhatsApp — Docker on same server) ───
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=your_waha_api_key
WAHA_WEBHOOK_SECRET=your_waha_webhook_secret

# ─── Meta WhatsApp Cloud API (alternative to WAHA) ───
# Note: Meta API credentials are stored PER-SESSION in the database.
# Each coach provides their OWN Meta API key via the /whatsapp/sessions API.
# No global Meta env vars needed — credentials are per-coach in DB.
# See DOCUMENTATION.md for setup instructions.

# ─── Base URL (for webhook configs) ───
BASE_URL=https://your-bluemq-domain.com

# ─── Service Auth ───
# Used to protect the /apps/register endpoint
SERVICE_API_KEY_SECRET=your_service_api_key_secret

# ─── Server ───
PORT=3001
